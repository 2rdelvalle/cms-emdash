diff --git a/src/api/public-url.ts b/src/api/public-url.ts
index cb5afb9b7595c518fef51fd639ede8cadfc84632..6a28c2f1acbd8a3ad88fa948e508d2b689f0e716 100644
--- a/src/api/public-url.ts
+++ b/src/api/public-url.ts
@@ -82,3 +82,17 @@ export function getPublicOrigin(url: URL, config?: EmDashConfig): string {
 export function getPublicUrl(url: URL, config: EmDashConfig | undefined, path: string): string {
 	return `${getPublicOrigin(url, config)}${path}`;
 }
+export function getForwardedRequestUrl(request: Request): URL {
+	const reqUrl = new URL(request.url);
+
+	const forwardedProto =
+		request.headers.get("x-forwarded-proto")?.split(",")[0]?.trim() ||
+		reqUrl.protocol.replace(":", "");
+
+	const forwardedHost =
+		request.headers.get("x-forwarded-host")?.split(",")[0]?.trim() ||
+		request.headers.get("host")?.split(",")[0]?.trim() ||
+		reqUrl.host;
+
+	return new URL(`${forwardedProto}://${forwardedHost}${reqUrl.pathname}${reqUrl.search}`);
+}
